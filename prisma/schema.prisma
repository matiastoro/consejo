generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  DIRECTOR
  SUBDIRECTOR
  JEFE_DOCENTE
  CONSEJERO
  INVITADO
  PROFESOR
}

enum TopicStatus {
  PENDING_APPROVAL
  DISCUSSING
  APROBADO
  RECHAZADO
  CERRADO
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  TOPIC_CREATED
  TOPIC_APPROVED
  TOPIC_CLOSED
  VOTE_CAST
  COMMENT_ADDED
  SESSION_SCHEDULED
  SESSION_STARTED
  PROVISIONAL_VOTE_REQUESTED
}

enum VoteType {
  A_FAVOR
  EN_CONTRA
  MAS_DATOS
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

model User {
  id            String     @id @default(cuid())
  name          String
  email         String?    @unique
  emailVerified DateTime?
  password      String
  image         String?
  roles         UserRole[] @default([PROFESOR])
  isAdmin       Boolean    @default(false)
  fullName      String?
  rut           String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts Account[]
  sessions Session[]
  profile  Profile?

  topicsCreated    Topic[]          @relation("TopicAuthor")
  votes            Vote[]
  comments         Comment[]
  readStatuses     TopicReadStatus[]
  topicEdits       TopicHistory[]
  topicNotes       TopicNote[]
  provisionalVotes ProvisionalVote[]
  notifications    Notification[]
  sessionsCreated  CouncilSession[] @relation("SessionCreator")
  membershipPeriods MembershipPeriod[]
  recusals         TopicRecusal[]
  sessionAttendances SessionAttendee[]

  @@map("users")
}

// ============================================
// MEMBERSHIP PERIODS (CONSEJERO / INVITADO)
// ============================================

model MembershipPeriod {
  id        String    @id @default(cuid())
  userId    String
  role      UserRole  // CONSEJERO | INVITADO
  startDate DateTime
  endDate   DateTime? // null = vigente/indefinido
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("membership_periods")
}

// ============================================
// TOPIC RECUSALS (conflicto de interés)
// ============================================

model TopicRecusal {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  createdAt DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@index([topicId])
  @@map("topic_recusals")
}

model DeniedLogin {
  id             String   @id @default(cuid())
  rut            String?
  email          String?
  name           String?
  identification String?
  reason         String
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@map("denied_logins")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  bio    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================
// TOPICS, VOTES & COMMENTS
// ============================================

model Topic {
  id                     String      @id @default(cuid())
  title                  String
  description            String      @db.Text
  status                 TopicStatus @default(PENDING_APPROVAL)
  priority               Int         @default(0)
  resolution             String?     @db.Text
  closedById             String?
  closedAt               DateTime?
  authorId               String
  inPersonOnly           Boolean     @default(false)
  requiresProvisionalVote Boolean    @default(false)
  resolvedInSessionId    String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  author           User              @relation("TopicAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  resolvedInSession CouncilSession?  @relation("TopicsResolvedInSession", fields: [resolvedInSessionId], references: [id], onDelete: SetNull)
  attachments      Attachment[]
  votes            Vote[]
  comments         Comment[]
  readStatuses     TopicReadStatus[]
  history          TopicHistory[]
  notes            TopicNote[]
  provisionalVotes ProvisionalVote[]
  sessionTopics    SessionTopic[]
  recusals         TopicRecusal[]

  @@map("topics")
}

model TopicHistory {
  id          String   @id @default(cuid())
  topicId     String
  userId      String
  field       String
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  createdAt   DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("topic_history")
}

model Attachment {
  id        String   @id @default(cuid())
  topicId   String?
  commentId String?
  noteId    String?
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())

  topic   Topic?     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  comment Comment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  note    TopicNote? @relation(fields: [noteId], references: [id], onDelete: Cascade)
  actaSelections SessionActaAttachment[]

  @@index([topicId])
  @@index([commentId])
  @@index([noteId])
  @@map("attachments")
}

model Vote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  voteType  VoteType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@map("votes")
}

model Comment {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@map("comments")
}

model TopicReadStatus {
  id            String   @id @default(cuid())
  topicId       String
  userId        String
  lastReadAt    DateTime @default(now())
  lastCommentId String?

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@map("topic_read_statuses")
}

// ============================================
// TOPIC NOTES (avances/apuntes)
// ============================================

model TopicNote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@map("topic_notes")
}

// ============================================
// PROVISIONAL VOTES
// ============================================

model ProvisionalVote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  voteType  VoteType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@map("provisional_votes")
}

// ============================================
// COUNCIL SESSIONS
// ============================================

model CouncilSession {
  id          String        @id @default(cuid())
  title       String
  date        DateTime
  location    String        @default("Dirección DCC")
  status      SessionStatus @default(SCHEDULED)
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy       User                    @relation("SessionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  topics          SessionTopic[]
  resolvedTopics  Topic[]                 @relation("TopicsResolvedInSession")
  attendees       SessionAttendee[]
  actaAttachments SessionActaAttachment[]
  acta            SessionActa?

  @@map("council_sessions")
}

// Quién asistió a una sesión. Se siembra desde los miembros con periodo
// activo a la fecha de la sesión; el director marca/desmarca asistencia.
// La presencia de la fila = asistió. isGuest separa "Asisten" de "Invitados".
model SessionAttendee {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  isGuest   Boolean  @default(false)
  createdAt DateTime @default(now())

  session CouncilSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@map("session_attendees")
}

// Acta generada y cacheada de una sesión. Una por sesión; "Regenerar" la
// reemplaza. La generación (sobre todo con LLM) corre en segundo plano: status
// pasa de PENDING a READY o ERROR y el archivo queda guardado en disco.
model SessionActa {
  id          String    @id @default(cuid())
  sessionId   String    @unique
  status      String    @default("PENDING") // PENDING | READY | ERROR
  mode        String    @default("RAW") // RAW | LLM
  fileUrl     String?
  fileSize    Int?
  error       String?
  generatedAt DateTime?
  requestedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  session CouncilSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_actas")
}

// Adjuntos PDF (de temas resueltos en la sesión) que se anexan al acta.
// Selección persistida y ordenable, elegida por el director/admin.
model SessionActaAttachment {
  id           String   @id @default(cuid())
  sessionId    String
  attachmentId String
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  session    CouncilSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  attachment Attachment     @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, attachmentId])
  @@index([sessionId])
  @@map("session_acta_attachments")
}

model SessionTopic {
  id          String    @id @default(cuid())
  sessionId   String
  topicId     String
  order       Int       @default(0)
  discussed   Boolean   @default(false)
  discussedAt DateTime?

  session CouncilSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  topic   Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([sessionId, topicId])
  @@map("session_topics")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  topicId   String?
  sessionId String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
