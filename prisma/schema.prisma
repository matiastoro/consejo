generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  DIRECTOR
  JEFE_DOCENTE
  CONSEJERO
  INVITADO
  PROFESOR
}

enum TopicStatus {
  PENDING_APPROVAL
  DISCUSSING
  APROBADO
  RECHAZADO
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  TOPIC_CREATED
  TOPIC_APPROVED
  TOPIC_CLOSED
  VOTE_CAST
  COMMENT_ADDED
  SESSION_SCHEDULED
  SESSION_STARTED
  PROVISIONAL_VOTE_REQUESTED
}

enum VoteType {
  A_FAVOR
  EN_CONTRA
  MAS_DATOS
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

model User {
  id            String     @id @default(cuid())
  name          String
  email         String?    @unique
  emailVerified DateTime?
  password      String
  image         String?
  roles         UserRole[] @default([PROFESOR])
  isAdmin       Boolean    @default(false)
  fullName      String?
  rut           String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts Account[]
  sessions Session[]
  profile  Profile?

  topicsCreated    Topic[]          @relation("TopicAuthor")
  votes            Vote[]
  comments         Comment[]
  readStatuses     TopicReadStatus[]
  topicEdits       TopicHistory[]
  topicNotes       TopicNote[]
  provisionalVotes ProvisionalVote[]
  notifications    Notification[]
  sessionsCreated  CouncilSession[] @relation("SessionCreator")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  bio    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================
// TOPICS, VOTES & COMMENTS
// ============================================

model Topic {
  id                     String      @id @default(cuid())
  title                  String
  description            String      @db.Text
  status                 TopicStatus @default(PENDING_APPROVAL)
  priority               Int         @default(0)
  resolution             String?     @db.Text
  closedById             String?
  closedAt               DateTime?
  authorId               String
  inPersonOnly           Boolean     @default(false)
  requiresProvisionalVote Boolean    @default(false)
  resolvedInSessionId    String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  author           User              @relation("TopicAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  resolvedInSession CouncilSession?  @relation("TopicsResolvedInSession", fields: [resolvedInSessionId], references: [id], onDelete: SetNull)
  attachments      Attachment[]
  votes            Vote[]
  comments         Comment[]
  readStatuses     TopicReadStatus[]
  history          TopicHistory[]
  notes            TopicNote[]
  provisionalVotes ProvisionalVote[]
  sessionTopics    SessionTopic[]

  @@map("topics")
}

model TopicHistory {
  id          String   @id @default(cuid())
  topicId     String
  userId      String
  field       String
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  createdAt   DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("topic_history")
}

model Attachment {
  id        String   @id @default(cuid())
  topicId   String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Vote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  voteType  VoteType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@map("votes")
}

model Comment {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model TopicReadStatus {
  id            String   @id @default(cuid())
  topicId       String
  userId        String
  lastReadAt    DateTime @default(now())
  lastCommentId String?

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@map("topic_read_statuses")
}

// ============================================
// TOPIC NOTES (avances/apuntes)
// ============================================

model TopicNote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("topic_notes")
}

// ============================================
// PROVISIONAL VOTES
// ============================================

model ProvisionalVote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  voteType  VoteType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@map("provisional_votes")
}

// ============================================
// COUNCIL SESSIONS
// ============================================

model CouncilSession {
  id          String        @id @default(cuid())
  title       String
  date        DateTime
  status      SessionStatus @default(SCHEDULED)
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy      User           @relation("SessionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  topics         SessionTopic[]
  resolvedTopics Topic[]        @relation("TopicsResolvedInSession")

  @@map("council_sessions")
}

model SessionTopic {
  id          String    @id @default(cuid())
  sessionId   String
  topicId     String
  order       Int       @default(0)
  discussed   Boolean   @default(false)
  discussedAt DateTime?

  session CouncilSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  topic   Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([sessionId, topicId])
  @@map("session_topics")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  topicId   String?
  sessionId String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
